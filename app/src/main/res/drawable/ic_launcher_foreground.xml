<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    
    <!-- Shadow backdrop path to give 3D depth -->
    <path
        android:pathData="M 54,20 C 35.22,20 20,35.22 20,54 C 20,72.78 35.22,88 54,88 C 72.78,88 88,72.78 88,54 C 88,35.22 72.78,20 54,20 Z"
        android:fillColor="#1F000000" />

    <!-- Sleek neural outer bubble stroke -->
    <path
        android:pathData="M 54,24 A 30,30 0 1,1 53.99,24 Z"
        android:strokeWidth="3.5"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="24"
                android:startY="24"
                android:endX="84"
                android:endY="84"
                android:type="linear">
                <item android:offset="0" android:color="#FFFBBF24" />
                <item android:offset="0.6" android:color="#FFFFFFFF" />
                <item android:offset="1" android:color="#FFEF4444" />
            </gradient>
        </aapt:attr>
    </path>
    
    <!-- Dynamic soundwave spectrum channels -->
    <path
        android:pathData="M 39,54 L 39,54 M 44,44 L 44,64 M 49,36 L 49,72 M 54,30 L 54,78 M 59,36 L 59,72 M 64,44 L 64,64 M 69,54 L 69,54"
        android:strokeWidth="3.5"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:startX="39"
                android:startY="54"
                android:endX="69"
                android:endY="54"
                android:type="linear">
                <item android:offset="0" android:color="#FFFFFFFF" />
                <item android:offset="0.5" android:color="#FFFBBF24" />
                <item android:offset="1" android:color="#FF7C3AED" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
